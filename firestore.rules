rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // telegram_users: только backend (Cloud Functions) через Admin SDK; клиент не имеет доступа
    match /telegram_users/{userId} {
      allow read, write: if false;
    }

    // Allow users to read and write their own user profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to read and write their own generations history
    match /generations/{document=**} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
