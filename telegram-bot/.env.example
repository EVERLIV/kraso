# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Webhook и верификация связи (опционально) ---
# Публичный HTTPS-URL вашего сервера (без слэша в конце). Если задан — бот работает по webhook, иначе по polling.
# Пример: https://your-domain.com  или  https://abc123.ngrok.io
PUBLIC_URL=

# Порт локального сервера (для webhook). По умолчанию 3000.
# PORT=3000

# Путь для приёма обновлений от Telegram. По умолчанию /webhook.
# Итоговый URL для setWebhook = PUBLIC_URL + WEBHOOK_PATH (например https://your-domain.com/webhook)
# WEBHOOK_PATH=/webhook

# --- Cloud Functions ---
# URL Cloud Function для генерации видео (Veo 3.1)
FAL_VEO_FUNCTION_URL=https://us-central1-project-1285666415996898989.cloudfunctions.net/generateFalVeoVideo

# URL Cloud Function для генерации изображений (Google Imagen)
GOOGLE_IMAGE_FUNCTION_URL=https://us-central1-project-1285666415996898989.cloudfunctions.net/generateGoogleImage
